def cmd_err(args):
    """Gestionare erori."""
    conn = get_db()
    cursor = conn.cursor()

    if not args or args[0] == "last":
        # Ultimele N erori
        limit = 10
        if len(args) >= 2:
            try:
                limit = int(args[1])
            except ValueError:
                limit = 10

        cursor.execute("""
            SELECT id, created_at, tool_name_resolved,
                   substr(error_message, 1, 80) as err_short,
                   resolved, source
            FROM errors_solutions
            ORDER BY id DESC
            LIMIT ?
        """, (limit,))

        rows = cursor.fetchall()
        if not rows:
            print("✅ Nicio eroare înregistrată.")
            return

        print(f"\n{'ID':>5} {'Data':>12} {'Tool':>20} {'Resolved':>8} {'Eroare':<50}")
        print("-" * 100)
        for row in rows:
            id_, created, tool, err, resolved, source = row
            date_short = created[:10] if created else "?"
            tool_short = (tool or "?")[:20]
            resolved_str = "✅" if resolved else "❌"
            err_short = (err or "")[:50].replace("\n", " ")
            print(f"{id_:>5} {date_short:>12} {tool_short:>20} {resolved_str:>8} {err_short:<50}")

        print(f"\nTotal: {len(rows)} erori afișate")

    elif args[0] == "resolve":
        if len(args) < 2:
            print("❌ Folosire: mem err resolve <id> -s \"soluție\"")
            return

        try:
            err_id = int(args[1])
        except ValueError:
            print("❌ ID invalid")
            return

        solution = ""
        if "-s" in args:
            idx = args.index("-s")
            if idx + 1 < len(args):
                solution = args[idx + 1]

        # Verifică dacă există coloana solution
        cursor.execute("PRAGMA table_info(errors_solutions)")
        columns = [row[1] for row in cursor.fetchall()]

        if "solution" in columns:
            cursor.execute("""
                UPDATE errors_solutions
                SET resolved = 1, solution = ?
                WHERE id = ?
            """, (solution, err_id))
        else:
            cursor.execute("""
                UPDATE errors_solutions
                SET resolved = 1
                WHERE id = ?
            """, (err_id,))

        conn.commit()
        if cursor.rowcount > 0:
            print(f"✅ Eroare #{err_id} marcată ca rezolvată")
            if solution:
                print(f"   Soluție: {solution}")
        else:
            print(f"❌ Eroare #{err_id} nu a fost găsită")

    elif args[0] == "unresolved":
        cursor.execute("""
            SELECT id, created_at, tool_name_resolved,
                   substr(error_message, 1, 60) as err_short
            FROM errors_solutions
            WHERE resolved = 0 OR resolved IS NULL
            ORDER BY id DESC
            LIMIT 20
        """)

        rows = cursor.fetchall()
        if not rows:
            print("✅ Toate erorile sunt rezolvate!")
            return

        print(f"\n{'ID':>5} {'Data':>12} {'Tool':>20} {'Eroare':<60}")
        print("-" * 100)
        for row in rows:
            id_, created, tool, err = row
            date_short = created[:10] if created else "?"
            tool_short = (tool or "?")[:20]
            err_short = (err or "")[:60].replace("\n", " ")
            print(f"{id_:>5} {date_short:>12} {tool_short:>20} {err_short:<60}")

        print(f"\n❌ {len(rows)} erori nerezolvate")

    conn.close()

def cmd_stats():
    """Statistici generale."""
    conn = get_db()
    cursor = conn.cursor()

    print("\n📊 STATISTICI MEMORIE PERMANENTĂ")
    print("=" * 50)

    # Mesaje
    cursor.execute("SELECT COUNT(*) FROM messages")
    msg_count = cursor.fetchone()[0]
    print(f"💬 Mesaje totale:        {msg_count:,}")

    # Sesiuni
    cursor.execute("SELECT COUNT(*) FROM sessions")
    sess_count = cursor.fetchone()[0]
    print(f"📁 Sesiuni totale:       {sess_count:,}")

    # Tool calls
    cursor.execute("SELECT COUNT(*) FROM tool_calls")
    tool_count = cursor.fetchone()[0]
    print(f"🔧 Tool calls:           {tool_count:,}")

    # Bash history
    cursor.execute("SELECT COUNT(*) FROM bash_history")
    bash_count = cursor.fetchone()[0]
    print(f"💻 Comenzi Bash:         {bash_count:,}")

    # Erori
    cursor.execute("SELECT COUNT(*) FROM errors_solutions")
    err_total = cursor.fetchone()[0]
    cursor.execute("SELECT COUNT(*) FROM errors_solutions WHERE resolved = 1")
    err_resolved = cursor.fetchone()[0]
    cursor.execute("SELECT COUNT(*) FROM errors_solutions WHERE source = 'auto_reconciler'")
    err_reconciler = cursor.fetchone()[0]
    print(f"❌ Erori totale:         {err_total:,}")
    print(f"✅ Erori rezolvate:      {err_resolved:,}")
    print(f"🔄 Din reconciler:       {err_reconciler:,}")

    # Checkpoints
    try:
        cursor.execute("SELECT COUNT(*), MAX(id) FROM checkpoints")
        cp_count, cp_last = cursor.fetchone()
        print(f"💾 Checkpoints:          {cp_count or 0:,} (ultim: #{cp_last or 0})")
    except:
        print(f"💾 Checkpoints:          N/A")

    # DB size
    db_size = DB_PATH.stat().st_size / (1024 * 1024)
    print(f"\n📦 Dimensiune DB:        {db_size:.1f} MB")

    # AUTOCOMPACT status
    autocompact = os.environ.get("CLAUDE_AUTOCOMPACT_PCT_OVERRIDE", "nesetat")
    print(f"⚙️  AUTOCOMPACT_OVERRIDE: {autocompact}")

    conn.close()

def cmd_trace(args):
    """Afișează trace logs sau reasoning traces."""
    # V15C: delegate to reasoning_trace.py for session/agent/entity subcommands
    if args and args[0] in ("session", "agent", "entity"):
        script = V2_SCRIPTS_DIR / "reasoning_trace.py"
        if script.exists():
            subprocess.run(["python3", str(script)] + args)
            return
        print(f"❌ Script lipsă: {script}")
        return

    # Fallback: old trace log viewer
    limit = 20
    if args:
        try:
            limit = int(args[0])
        except ValueError:
            limit = 20

    print("\n📋 COMPACT TRACE LOG")
    print("-" * 50)
    if TRACE_LOG.exists():
        lines = TRACE_LOG.read_text().strip().split("\n")
        for line in lines[-limit:]:
            print(line)
    else:
        print("(gol)")

    print("\n⚠️  DAEMON WARNINGS LOG")
    print("-" * 50)
    if WARNINGS_LOG.exists():
        lines = WARNINGS_LOG.read_text().strip().split("\n")
        for line in lines[-limit:]:
            print(line)
    else:
        print("(gol)")

