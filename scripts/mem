def cmd_search(args):
    """Caută în memorie — unified cognitive search."""
    if not args:
        print("❌ Folosire: mem search <query> [--scope all|raw|structured|errors] [-l LIMIT]")
        print("   Aliases: --messages, --commands, --errors (backward compat)")
        return

    query = args[0]
    flags = args[1:] if len(args) > 1 else []

    # New unified search via cognitive_search.py
    cognitive_script = V2_SCRIPTS_DIR / "cognitive_search.py"
    if cognitive_script.exists():
        cmd = ["python3", str(cognitive_script), query]
        if "--scope" in flags:
            idx = flags.index("--scope")
            if idx + 1 < len(flags):
                cmd.extend(["--scope", flags[idx + 1]])
        elif "--raw" in flags or "--messages" in flags or "--commands" in flags:
            cmd.extend(["--scope", "raw"])
        elif "--structured" in flags:
            cmd.extend(["--scope", "structured"])
        elif "--errors" in flags:
            cmd.extend(["--scope", "errors"])
        if "-l" in flags:
            idx = flags.index("-l")
            if idx + 1 < len(flags):
                cmd.extend(["-l", flags[idx + 1]])
        subprocess.run(cmd)
    else:
        # Fallback to old search
        script = SCRIPTS_DIR / "search_memory.py"
        if not script.exists():
            print(f"❌ Script lipsă: {script}")
            return
        cmd = ["python3", str(script), query]
        if "--messages" in flags:
            cmd.append("--messages")
        elif "--commands" in flags:
            cmd.append("--commands")
        elif "--errors" in flags:
            cmd.append("--errors")
        subprocess.run(cmd)


