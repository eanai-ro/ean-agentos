import sqlite3
import subprocess
from pathlib import Path
from datetime import datetime

# Paths — rezolvare relativă la locația scriptului (portabil)
V2_SCRIPTS_DIR = Path(__file__).parent
SCRIPTS_DIR = V2_SCRIPTS_DIR  # Unified: toate scripturile sunt în același director

# DB path via v2_common resolver
try:
    sys.path.insert(0, str(V2_SCRIPTS_DIR))
    from v2_common import resolve_db_path
    DB_PATH = resolve_db_path()
except ImportError:
    DB_PATH = Path.home() / ".claude" / "memory" / "global.db"

# Log paths
PROJECT_ROOT = V2_SCRIPTS_DIR.parent
TRACE_LOG = PROJECT_ROOT / "compact_trace.log"
WARNINGS_LOG = PROJECT_ROOT / "daemon_warnings.log"
MEMORY_DIR = PROJECT_ROOT  # Compatibilitate

def get_db():
    """Conectare la baza de date."""
    if not DB_PATH.exists():
        print(f"❌ Baza de date nu există: {DB_PATH}")
        sys.exit(1)
    return sqlite3.connect(DB_PATH)

