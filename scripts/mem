def cmd_review(args):
    """Review auto-extracted items."""
    conn = get_db()
    cursor = conn.cursor()

    sub = args[0] if args else "pending"

    if sub == "pending":
        # List pending items
        for table, item_type, text_col, active_filter in [
            ("decisions", "DECISION", "title", "status='active'"),
            ("learned_facts", "FACT", "fact", "is_active=1"),
            ("error_resolutions", "RESOLUTION", "resolution", "1=1"),
        ]:
            try:
                cursor.execute(
                    f"SELECT id, {text_col}, extraction_confidence, topics, created_at "
                    f"FROM {table} WHERE auto_extracted=1 AND {active_filter} "
                    f"ORDER BY created_at DESC LIMIT 20"
                )
                rows = cursor.fetchall()
                if rows:
                    print(f"\n  [{item_type}] ({len(rows)} pending)")
                    for r in rows:
                        topics = f" [{r[3]}]" if r[3] else ""
                        print(f"    #{r[0]} (conf={r[2]:.2f}{topics}) {r[1][:60]}")
            except Exception:
                pass

    elif sub == "approve" and len(args) >= 3:
        item_type, item_id = args[1], int(args[2])
        updates = {
            "decision": ("decisions", "confidence='confirmed', auto_extracted=2"),
            "fact": ("learned_facts", "confidence='confirmed', auto_extracted=2"),
            "resolution": ("error_resolutions", "worked=1, auto_extracted=2"),
        }
        if item_type in updates:
            table, sql = updates[item_type]
            cursor.execute(f"UPDATE {table} SET {sql} WHERE id=?", (item_id,))
            conn.commit()
            print(f"  ✅ Approved {item_type} #{item_id}")
        else:
            print(f"  ❌ Tip necunoscut: {item_type}")

    elif sub == "reject" and len(args) >= 3:
        item_type, item_id = args[1], int(args[2])
        updates = {
            "decision": ("decisions", "status='rejected', auto_extracted=-1"),
            "fact": ("learned_facts", "is_active=0, auto_extracted=-1"),
            "resolution": ("error_resolutions", "worked=0, auto_extracted=-1"),
        }
        if item_type in updates:
            table, sql = updates[item_type]
            cursor.execute(f"UPDATE {table} SET {sql} WHERE id=?", (item_id,))
            conn.commit()
            print(f"  ❌ Rejected {item_type} #{item_id}")
        else:
            print(f"  ❌ Tip necunoscut: {item_type}")

    elif sub == "stats":
        for table, item_type in [("decisions", "decision"), ("learned_facts", "fact"), ("error_resolutions", "resolution")]:
            try:
                cursor.execute(f"SELECT COUNT(*) FROM {table} WHERE auto_extracted=1")
                pending = cursor.fetchone()[0]
                cursor.execute(f"SELECT COUNT(*) FROM {table} WHERE auto_extracted=2")
                approved = cursor.fetchone()[0]
                cursor.execute(f"SELECT COUNT(*) FROM {table} WHERE auto_extracted=-1")
                rejected = cursor.fetchone()[0]
                print(f"  {item_type}: pending={pending} approved={approved} rejected={rejected}")
            except Exception:
                pass
    else:
        print("  Usage: mem review [pending|approve|reject|stats]")
        print("    mem review pending           — Items de revizuit")
        print("    mem review approve <type> <id> — Aprobă item")
        print("    mem review reject <type> <id>  — Rejectează item")
        print("    mem review stats              — Statistici review")

    conn.close()


def cmd_orch(args):
    """Orchestrare multi-agent (18D-20). Requires Pro license."""
    if not args:
        args = ["help"]

    subcmd = args[0]

    # License gate (only active when ORCH_LICENSE_CHECK=1)
    if subcmd != "help" and subcmd not in ("", None):
        if os.environ.get("ORCH_LICENSE_CHECK") == "1":
            try:
                sys.path.insert(0, str(V2_SCRIPTS_DIR))
                from license_gate import require_premium
                require_premium("orchestration")
            except SystemExit:
                return
            except ImportError:
                pass
    sub_args = args[1:]

    # Detectăm CLI-ul curent din env sau default
    cli_name = os.environ.get("MEMORY_AGENT_NAME", "claude-code")

    if subcmd == "create":
        if not sub_args:
            print("  Usage: mem orch create <title> [description]")
            return
        title = sub_args[0]
        desc = sub_args[1] if len(sub_args) > 1 else ""
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        subprocess.run(["python3", str(script), "create-project", title, desc, cli_name])

    elif subcmd == "status":
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        if sub_args:
            subprocess.run(["python3", str(script), "status", sub_args[0]])
        else:
            # Listează toate proiectele active
            sys.path.insert(0, str(V2_SCRIPTS_DIR))
            from v2_common import get_db as v2_get_db
            conn = v2_get_db()
            cur = conn.cursor()
            cur.execute("SELECT id, title, orchestrator_cli, status, created_at FROM orchestration_projects ORDER BY created_at DESC LIMIT 10")
            rows = cur.fetchall()
            conn.close()
            if not rows:
                print("  Niciun proiect orchestrat.")
            else:
                print(f"  {'ID':<5} {'Titlu':<30} {'Orchestrator':<15} {'Status':<10} {'Creat':<16}")
                print(f"  {'-'*5} {'-'*30} {'-'*15} {'-'*10} {'-'*16}")
                for r in rows:
                    print(f"  {r[0]:<5} {r[1][:30]:<30} {r[2]:<15} {r[3]:<10} {str(r[4])[:16]:<16}")

    elif subcmd == "add-task":
        if len(sub_args) < 3:
            print("  Usage: mem orch add-task <project_id> <title> <description> [--type X] [--priority X] [--skills a,b]")
            return
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        cmd = ["python3", str(script), "add-task"] + sub_args + ["--created-by", cli_name]
        subprocess.run(cmd)

    elif subcmd == "tasks":
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        if "--mine" in sub_args:
            subprocess.run(["python3", str(script), "my-tasks", cli_name])
        elif "--available" in sub_args:
            subprocess.run(["python3", str(script), "tasks", cli_name])
        else:
            subprocess.run(["python3", str(script), "tasks"])

    elif subcmd == "claim":
        if not sub_args:
            print("  Usage: mem orch claim <task_id>")
            return
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        subprocess.run(["python3", str(script), "claim", sub_args[0], cli_name])

    elif subcmd == "done":
        if not sub_args:
            print("  Usage: mem orch done <task_id> [summary]")
            return
        # Trebuie lease_token — îl citim din task
        sys.path.insert(0, str(V2_SCRIPTS_DIR))
        from v2_common import get_db as v2_get_db
        conn = v2_get_db()
        cur = conn.cursor()
        cur.execute("SELECT lease_token FROM orch_tasks WHERE id = ? AND assigned_cli = ?",
                     (int(sub_args[0]), cli_name))
        row = cur.fetchone()
        conn.close()
        if not row or not row[0]:
            print(f"  ❌ Nu ai lease pe task #{sub_args[0]}")
            return
        summary = sub_args[1] if len(sub_args) > 1 else ""
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        subprocess.run(["python3", str(script), "complete", sub_args[0], row[0], summary])

    elif subcmd == "deliberate":
        if not sub_args:
            print("  Usage: mem orch deliberate <topic> [--type quick|deep|expert]")
            return
        script = V2_SCRIPTS_DIR / "deliberation.py"
        cmd = ["python3", str(script), "create", sub_args[0], "--started-by", cli_name]
        for i, arg in enumerate(sub_args[1:], 1):
            if arg == "--type" and i + 1 < len(sub_args):
                cmd += ["--type", sub_args[i + 1]]
        subprocess.run(cmd)

    elif subcmd == "propose":
        if len(sub_args) < 2:
            print("  Usage: mem orch propose <session_id> <content> [--confidence 0.8]")
            return
        script = V2_SCRIPTS_DIR / "deliberation.py"
        cmd = ["python3", str(script), "propose", sub_args[0], cli_name, sub_args[1]]
        for i, arg in enumerate(sub_args[2:], 2):
            if arg == "--confidence" and i + 1 < len(sub_args):
                cmd += ["--confidence", sub_args[i + 1]]
        subprocess.run(cmd)

    elif subcmd == "vote":
        if len(sub_args) < 2:
            print("  Usage: mem orch vote <session_id> <option> [reasoning]")
            return
        script = V2_SCRIPTS_DIR / "deliberation.py"
        cmd = ["python3", str(script), "vote", sub_args[0], cli_name, sub_args[1]]
        if len(sub_args) > 2:
            cmd.append(sub_args[2])
        subprocess.run(cmd)

    elif subcmd == "send":
        if len(sub_args) < 2:
            print("  Usage: mem orch send <to_cli|all> <message> [--type info|question|review]")
            return
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        to = sub_args[0] if sub_args[0] != "all" else None
        cmd = ["python3", str(script), "send", cli_name, sub_args[1]]
        if to:
            cmd += ["--to", to]
        for i, arg in enumerate(sub_args[2:], 2):
            if arg == "--type" and i + 1 < len(sub_args):
                cmd += ["--type", sub_args[i + 1]]
        subprocess.run(cmd)

    elif subcmd == "messages":
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        cmd = ["python3", str(script), "messages", "--to", cli_name]
        if "--unread" in sub_args:
            cmd.append("--unread")
        subprocess.run(cmd)

    elif subcmd == "agents":
        script = V2_SCRIPTS_DIR / "orchestrator.py"
        subprocess.run(["python3", str(script), "agents"])

    elif subcmd == "daemon":
        script = V2_SCRIPTS_DIR / "orch_daemon.py"
        cmd = ["python3", str(script)]
        if "--once" in sub_args:
            cmd.append("--once")
        subprocess.run(cmd)

    elif subcmd == "launch":
        script = V2_SCRIPTS_DIR / "cli_launcher.py"
        if len(sub_args) < 2:
            print("  Usage: mem orch launch <cli_name> --task <id> [--timeout 300] [--perm safe|auto|unsafe]")
            print("         mem orch launch <cli_name> --deliberate <session_id>")
            print("         mem orch launch <cli_name> --prompt 'text'")
            return
        cli_name = sub_args[0]
        cmd = ["python3", str(script)]
        if "--task" in sub_args:
            idx = sub_args.index("--task")
            cmd += ["task", cli_name, sub_args[idx + 1]]
        elif "--deliberate" in sub_args:
            idx = sub_args.index("--deliberate")
            cmd += ["deliberate", cli_name, sub_args[idx + 1]]
        elif "--prompt" in sub_args:
            idx = sub_args.index("--prompt")
            cmd += ["prompt", cli_name, sub_args[idx + 1]]
        else:
            print("  Specifică --task, --deliberate, sau --prompt")
            return
        # Pass through optional flags
        for flag in ["--timeout", "--perm", "--dir"]:
            if flag in sub_args:
                fi = sub_args.index(flag)
                if fi + 1 < len(sub_args):
                    cmd += [flag, sub_args[fi + 1]]
        subprocess.run(cmd)

    elif subcmd == "launches":
        script = V2_SCRIPTS_DIR / "cli_launcher.py"
        subprocess.run(["python3", str(script), "launches"])

    elif subcmd == "deliberate-auto":
        if len(sub_args) < 1:
            print("  Usage: mem orch deliberate-auto <question> [--type deep] [--timeout 120]")
            return
        script = V2_SCRIPTS_DIR / "auto_loop.py"
        cmd = ["python3", str(script), "deliberate", sub_args[0]]
        for flag in ["--type", "--timeout", "--perm", "--participants"]:
            if flag in sub_args:
                fi = sub_args.index(flag)
                if fi + 1 < len(sub_args):
                    cmd += [flag, sub_args[fi + 1]]
        subprocess.run(cmd)

    elif subcmd == "run-project":
        if len(sub_args) < 1:
            print("  Usage: mem orch run-project <project_id> [--timeout 300] [--review]")
            return
        script = V2_SCRIPTS_DIR / "auto_loop.py"
        cmd = ["python3", str(script), "run-project", sub_args[0]]
        for flag in ["--timeout", "--perm"]:
            if flag in sub_args:
                fi = sub_args.index(flag)
                if fi + 1 < len(sub_args):
                    cmd += [flag, sub_args[fi + 1]]
        if "--review" in sub_args:
            cmd.append("--review")
        if "--auto-fix" in sub_args:
            cmd.append("--auto-fix")
        subprocess.run(cmd)

    elif subcmd == "review":
        if len(sub_args) < 1:
            print("  Usage: mem orch review <task_id> --by <cli_name>")
            return
        task_id = sub_args[0]
        reviewer = "gemini-cli"
        if "--by" in sub_args:
            idx = sub_args.index("--by")
            if idx + 1 < len(sub_args):
                reviewer = sub_args[idx + 1]
        script = V2_SCRIPTS_DIR / "cli_launcher.py"
        # Use python to call launch_for_review
        subprocess.run(["python3", "-c",
            f"import sys; sys.path.insert(0,'{V2_SCRIPTS_DIR}'); "
            f"from cli_launcher import launch_for_review; "
            f"import json; r=launch_for_review('{reviewer}',{task_id}); "
            f"print(json.dumps(r,indent=2,default=str,ensure_ascii=False))"])

    elif subcmd == "reviews":
        import sqlite3
        conn = sqlite3.connect(str(DB_PATH))
        conn.row_factory = sqlite3.Row
        cur = conn.cursor()
        query = "SELECT r.id, r.task_id, r.reviewer_cli, r.verdict, r.severity, r.original_cli, r.created_at FROM orch_reviews r"
        params = []
        conditions = []
        if "--task" in sub_args:
            idx = sub_args.index("--task")
            if idx + 1 < len(sub_args):
                conditions.append("r.task_id = ?")
                params.append(int(sub_args[idx + 1]))
        if "--verdict" in sub_args:
            idx = sub_args.index("--verdict")
            if idx + 1 < len(sub_args):
                conditions.append("r.verdict = ?")
                params.append(sub_args[idx + 1])
        if conditions:
            query += " WHERE " + " AND ".join(conditions)
        query += " ORDER BY r.created_at DESC LIMIT 20"
        cur.execute(query, params)
        rows = cur.fetchall()
        conn.close()
        if not rows:
            print("  Niciun review găsit.")
        else:
            print(f"  {'ID':<5} {'Task':<6} {'Reviewer':<15} {'Verdict':<20} {'Severity':<10} {'Original':<15} {'Creat':<16}")
            print("  " + "-" * 87)
            for r in rows:
                print(f"  {r['id']:<5} #{r['task_id']:<5} {r['reviewer_cli']:<15} {r['verdict']:<20} {r['severity']:<10} {r['original_cli'] or '-':<15} {r['created_at'][:16]}")

    elif subcmd == "replay":
        if len(sub_args) < 1:
            print("  Usage: mem orch replay <project_id> [--json]")
            return
        script = V2_SCRIPTS_DIR / "replay.py"
        cmd = ["python3", str(script), "project", sub_args[0]]
        if "--json" in sub_args:
            cmd.append("--json")
        subprocess.run(cmd)

    elif subcmd == "replay-delib":
        if len(sub_args) < 1:
            print("  Usage: mem orch replay-delib <session_id> [--json]")
            return
        script = V2_SCRIPTS_DIR / "replay.py"
        cmd = ["python3", str(script), "deliberation", sub_args[0]]
        if "--json" in sub_args:
            cmd.append("--json")
        subprocess.run(cmd)

    elif subcmd == "capabilities":
        script = V2_SCRIPTS_DIR / "intelligence.py"
        subprocess.run(["python3", str(script), "leaderboard"])

    elif subcmd == "skills":
        if len(sub_args) < 1:
            # All CLIs
            script = V2_SCRIPTS_DIR / "intelligence.py"
            subprocess.run(["python3", "-c",
                f"import sys; sys.path.insert(0,'{V2_SCRIPTS_DIR}'); "
                f"from intelligence import get_learned_skills; "
                f"from v2_common import VALID_CLI_NAMES; "
                f"import json; "
                f"[print(f'  {{cli}}:', json.dumps(get_learned_skills(cli), indent=4)) for cli in VALID_CLI_NAMES]"])
        else:
            cli_name = sub_args[0]
            subprocess.run(["python3", "-c",
                f"import sys; sys.path.insert(0,'{V2_SCRIPTS_DIR}'); "
                f"from intelligence import get_learned_skills; "
                f"import json; print(json.dumps(get_learned_skills('{cli_name}'), indent=2))"])

    else:
        print("  Orchestration — Comenzi:")
        print("    mem orch create <title>           — Creează proiect")
        print("    mem orch status [project_id]      — Status")
        print("    mem orch add-task <p> <t> <d>     — Adaugă task")
        print("    mem orch tasks [--mine|--available]— Listează task-uri")
        print("    mem orch claim <task_id>          — Claim task")
        print("    mem orch done <task_id> [summary] — Marchează done")
        print("    mem orch deliberate <topic>       — Pornește deliberare manuală")
        print("    mem orch propose <sid> <text>     — Propunere")
        print("    mem orch vote <sid> <option>      — Votează")
        print("    mem orch send <to> <mesaj>        — Mesaj inter-agent")
        print("    mem orch messages [--unread]      — Citește mesaje")
        print("    mem orch agents                   — Status agenți")
        print("    mem orch daemon [--once]          — Housekeeping daemon")
        print("    mem orch launch <cli> --task <id> — Lansează CLI pentru task")
        print("    mem orch launches                 — Listează launch-uri active")
        print("    mem orch deliberate-auto <q>      — Deliberare AUTOMATĂ")
        print("    mem orch run-project <id> [--review] — Rulează task-uri (+auto review)")
        print("    mem orch review <task_id> --by <cli> — Peer review pe un task")
        print("    mem orch reviews [--task X]       — Listează reviews")
        print("    mem orch replay <project_id>      — Timeline proiect")
        print("    mem orch replay-delib <session_id> — Timeline deliberare")
        print("    mem orch capabilities             — Leaderboard capabilities")


def cmd_model(args):
    """Gestionare model/provider curent."""
    script = V2_SCRIPTS_DIR / "model_logger.py"
    if not script.exists():
        print(f"❌ Script lipsă: {script}")
        return

    if args and args[0] in ("set", "show", "clear"):
        cmd = ["python3", str(script)] + args
    else:
        # Default: show
        cmd = ["python3", str(script), "show"] + args

    subprocess.run(cmd)


def main():
    if len(sys.argv) < 2:
        cmd_help()
        return

    command = sys.argv[1].lower()
    args = sys.argv[2:]

    commands = {
        "help": lambda: cmd_help(),
        "backup": lambda: cmd_backup(args),
        "doctor": lambda: cmd_doctor(args),
        "quarantine": lambda: cmd_quarantine(args),
        "panic": lambda: cmd_panic(args),
        "status": lambda: cmd_status(args),
        "audit": lambda: cmd_audit(args),
        "fp": lambda: cmd_fp(args),
        "search": lambda: cmd_search(args),
        "err": lambda: cmd_err(args),
        "error": lambda: cmd_err(args),
        "errors": lambda: cmd_err(args),
        "stats": lambda: cmd_stats(),
        "trace": lambda: cmd_trace(args),
        "reconcile": lambda: cmd_reconcile(args),
        "reload": lambda: cmd_reload(args),
        # V2: Decisions + Facts
        "decide": lambda: cmd_decide(args),
        "decisions": lambda: cmd_decisions(args),
        "learn": lambda: cmd_learn(args),
        "pin": lambda: cmd_pin(args),
        "unpin": lambda: cmd_unpin(args),
        # V2: Goals, Tasks, Projects
        "goal": lambda: cmd_goal(args),
        "task": lambda: cmd_task(args),
        "project": lambda: cmd_project(args),
        # V2C: Error Intelligence + Model Attribution
        "resolve": lambda: cmd_resolve(args),
        "model": lambda: cmd_model(args),
        # V2: Context Builder + Intent + Strategy
        "context": lambda: cmd_context(args),
        "intent": lambda: cmd_intent(args),
        "strategy": lambda: cmd_strategy(args),
        # V4: Intelligence Layer
        "patterns": lambda: cmd_patterns(args),
        "intelligence": lambda: cmd_intelligence(args),
        "cleanup": lambda: cmd_cleanup(args),
        "promote": lambda: cmd_promote(args),
        # V5A: Checkpoints + Timeline
        "dashboard": lambda: cmd_dashboard(args),
        "checkpoint": lambda: cmd_checkpoint(args),
        "timeline": lambda: cmd_timeline(args),
        # V5E: Activity Log
        "activity": lambda: cmd_activity(args),
        # V12A: Agent Event Stream
        "events": lambda: cmd_events(args),
        # V9: Memory Branches
        "branch": lambda: cmd_branch(args),
        # V15B: Cognitive Memory
        "errorlearn": lambda: cmd_errorlearn(args),
        # V15C: Cognitive Memory Stage 2
        "replay": lambda: cmd_replay(args),
        "learnings": lambda: cmd_learnings(args),
        # V15D: Memory Intelligence Layer
        "score": lambda: cmd_score(args),
        "graph": lambda: cmd_graph(args),
        "suggest": lambda: cmd_suggest(args),
        # 18C: Review auto-extracted items
        "review": lambda: cmd_review(args),
        # 18D: Orchestration
        "orch": lambda: cmd_orch(args),
    }

    if command in commands:
        commands[command]()
    else:
        print(f"❌ Comandă necunoscută: {command}")
        print("   Folosește: mem help")

if __name__ == "__main__":
    main()
