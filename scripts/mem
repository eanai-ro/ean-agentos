def cmd_resolve(args):
    """Gestionare rezolvări erori."""
    script = V2_SCRIPTS_DIR / "error_resolution.py"
    if not script.exists():
        print(f"❌ Script lipsă: {script}")
        return

    if args and args[0] in ("list", "show", "search"):
        cmd = ["python3", str(script)] + args
    else:
        # Default: add — primul arg e error_id
        # mem resolve <id> -s "..." → error_resolution.py add --error-id <id> -s "..."
        if args and args[0].isdigit():
            cmd = ["python3", str(script), "add", "--error-id"] + args
        else:
            cmd = ["python3", str(script), "add"] + args

    subprocess.run(cmd)


def cmd_review(args):
    """Review auto-extracted items."""
    conn = get_db()
    cursor = conn.cursor()

    sub = args[0] if args else "pending"

    if sub == "pending":
        # List pending items
        for table, item_type, text_col, active_filter in [
            ("decisions", "DECISION", "title", "status='active'"),
            ("learned_facts", "FACT", "fact", "is_active=1"),
            ("error_resolutions", "RESOLUTION", "resolution", "1=1"),
        ]:
            try:
                cursor.execute(
                    f"SELECT id, {text_col}, extraction_confidence, topics, created_at "
                    f"FROM {table} WHERE auto_extracted=1 AND {active_filter} "
                    f"ORDER BY created_at DESC LIMIT 20"
                )
                rows = cursor.fetchall()
                if rows:
                    print(f"\n  [{item_type}] ({len(rows)} pending)")
                    for r in rows:
                        topics = f" [{r[3]}]" if r[3] else ""
                        print(f"    #{r[0]} (conf={r[2]:.2f}{topics}) {r[1][:60]}")
            except Exception:
                pass

    elif sub == "approve" and len(args) >= 3:
        item_type, item_id = args[1], int(args[2])
        updates = {
            "decision": ("decisions", "confidence='confirmed', auto_extracted=2"),
            "fact": ("learned_facts", "confidence='confirmed', auto_extracted=2"),
            "resolution": ("error_resolutions", "worked=1, auto_extracted=2"),
        }
        if item_type in updates:
            table, sql = updates[item_type]
            cursor.execute(f"UPDATE {table} SET {sql} WHERE id=?", (item_id,))
            conn.commit()
            print(f"  ✅ Approved {item_type} #{item_id}")
        else:
            print(f"  ❌ Tip necunoscut: {item_type}")

    elif sub == "reject" and len(args) >= 3:
        item_type, item_id = args[1], int(args[2])
        updates = {
            "decision": ("decisions", "status='rejected', auto_extracted=-1"),
            "fact": ("learned_facts", "is_active=0, auto_extracted=-1"),
            "resolution": ("error_resolutions", "worked=0, auto_extracted=-1"),
        }
        if item_type in updates:
            table, sql = updates[item_type]
            cursor.execute(f"UPDATE {table} SET {sql} WHERE id=?", (item_id,))
            conn.commit()
            print(f"  ❌ Rejected {item_type} #{item_id}")
        else:
            print(f"  ❌ Tip necunoscut: {item_type}")

    elif sub == "stats":
        for table, item_type in [("decisions", "decision"), ("learned_facts", "fact"), ("error_resolutions", "resolution")]:
            try:
                cursor.execute(f"SELECT COUNT(*) FROM {table} WHERE auto_extracted=1")
                pending = cursor.fetchone()[0]
                cursor.execute(f"SELECT COUNT(*) FROM {table} WHERE auto_extracted=2")
                approved = cursor.fetchone()[0]
                cursor.execute(f"SELECT COUNT(*) FROM {table} WHERE auto_extracted=-1")
                rejected = cursor.fetchone()[0]
                print(f"  {item_type}: pending={pending} approved={approved} rejected={rejected}")
            except Exception:
                pass
    else:
        print("  Usage: mem review [pending|approve|reject|stats]")
        print("    mem review pending           — Items de revizuit")
        print("    mem review approve <type> <id> — Aprobă item")
        print("    mem review reject <type> <id>  — Rejectează item")
        print("    mem review stats              — Statistici review")

    conn.close()


def cmd_model(args):
    """Gestionare model/provider curent."""
    script = V2_SCRIPTS_DIR / "model_logger.py"
    if not script.exists():
        print(f"❌ Script lipsă: {script}")
        return

    if args and args[0] in ("set", "show", "clear"):
        cmd = ["python3", str(script)] + args
    else:
        # Default: show
        cmd = ["python3", str(script), "show"] + args

    subprocess.run(cmd)


def main():
    if len(sys.argv) < 2:
        cmd_help()
        return

    command = sys.argv[1].lower()
    args = sys.argv[2:]

    commands = {
        "help": lambda: cmd_help(),
        "backup": lambda: cmd_backup(args),
        "doctor": lambda: cmd_doctor(args),
        "panic": lambda: cmd_panic(args),
        "status": lambda: cmd_status(args),
        "audit": lambda: cmd_audit(args),
        "fp": lambda: cmd_fp(args),
        "search": lambda: cmd_search(args),
        "err": lambda: cmd_err(args),
        "error": lambda: cmd_err(args),
        "errors": lambda: cmd_err(args),
        "stats": lambda: cmd_stats(),
        "trace": lambda: cmd_trace(args),
        "reconcile": lambda: cmd_reconcile(args),
        "reload": lambda: cmd_reload(args),
        # Error Resolution + Model Attribution
        "resolve": lambda: cmd_resolve(args),
        "model": lambda: cmd_model(args),
        # Context Builder + Intent + Strategy
        "context": lambda: cmd_context(args),
        "intent": lambda: cmd_intent(args),
        "strategy": lambda: cmd_strategy(args),
        # Intelligence Layer
        "patterns": lambda: cmd_patterns(args),
        "intelligence": lambda: cmd_intelligence(args),
        "cleanup": lambda: cmd_cleanup(args),
        "promote": lambda: cmd_promote(args),
        # Dashboard
        "dashboard": lambda: cmd_dashboard(args),
        # Memory Branches
        "branch": lambda: cmd_branch(args),
        # Cognitive Memory
        "errorlearn": lambda: cmd_errorlearn(args),
        "replay": lambda: cmd_replay(args),
        "learnings": lambda: cmd_learnings(args),
        # Memory Intelligence Layer
        "score": lambda: cmd_score(args),
        "graph": lambda: cmd_graph(args),
        "suggest": lambda: cmd_suggest(args),
        # Review auto-extracted items
        "review": lambda: cmd_review(args),
    }

    if command in commands:
        commands[command]()
    else:
        print(f"❌ Comandă necunoscută: {command}")
        print("   Folosește: mem help")

if __name__ == "__main__":
    main()
