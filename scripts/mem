def cmd_panic(args):
    """Incident response și secrets hunt."""
    script = SCRIPTS_DIR / "mem_panic.py"
    if not script.exists():
        print(f"❌ Script panic lipsă: {script}")
        return

    # Pasează toate args către mem_panic.py
    cmd = ["python3", str(script)] + args
    result = subprocess.run(cmd)
    sys.exit(result.returncode)

