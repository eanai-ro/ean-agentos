def cmd_intent(args):
    """Gestionare session intent."""
    sys.path.insert(0, str(V2_SCRIPTS_DIR))
    from v2_common import (
        get_current_intent, set_current_intent, clear_current_intent,
        invalidate_snapshot, VALID_INTENTS,
    )

    if not args or args[0] == "show":
        intent = get_current_intent()
        if intent:
            print(f"Intent curent: {intent}")
        else:
            print("Niciun intent setat.")
            print(f"  Valide: {', '.join(VALID_INTENTS)}")
    elif args[0] == "set":
        if len(args) < 2:
            print(f"❌ Folosire: mem intent set <intent>")
            print(f"   Valide: {', '.join(VALID_INTENTS)}")
            return
        intent = args[1].lower()
        if intent not in VALID_INTENTS:
            print(f"❌ Intent invalid: {intent}")
            print(f"   Valide: {', '.join(VALID_INTENTS)}")
            return
        set_current_intent(intent)
        invalidate_snapshot()
        print(f"✅ Intent setat: {intent}")
    elif args[0] == "clear":
        clear_current_intent()
        invalidate_snapshot()
        print("✅ Intent șters.")
    else:
        print(f"❌ Subcomandă necunoscută: {args[0]}")
        print("   Valide: set, show, clear")


def cmd_context(args):
    """Context Builder V2. Fără flags → auto strategy."""
    # Dacă nu are flag-uri de mod explicit, folosește auto strategy
    mode_flags = {"--compact", "--full", "--survival", "--delta"}
    has_mode = any(f in args for f in mode_flags)

    if not has_mode and "--json" not in args:
        # Auto strategy mode
        script = V2_SCRIPTS_DIR / "context_strategy.py"
        if script.exists():
            sys.path.insert(0, str(V2_SCRIPTS_DIR))
            try:
                from context_strategy import choose_context_mode
                strategy = choose_context_mode(trigger="manual")
                mode = strategy["mode"]
                auto_args = list(args)
                if mode == "delta":
                    auto_args.append("--delta")
                else:
                    auto_args.append(f"--{mode}")
                if strategy.get("budget") and strategy["budget"] < 99999:
                    auto_args.extend(["--budget", str(strategy["budget"])])

                script_ctx = V2_SCRIPTS_DIR / "context_builder_v2.py"
                cmd = ["python3", str(script_ctx)] + auto_args
                subprocess.run(cmd)
                return
            except Exception:
                pass  # Fallback to default

    script = V2_SCRIPTS_DIR / "context_builder_v2.py"
    if not script.exists():
        print(f"❌ Script lipsă: {script}")
        return
    cmd = ["python3", str(script)] + args
    subprocess.run(cmd)


