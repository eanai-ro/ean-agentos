def cmd_patterns(args):
    """Error pattern detection."""
    script = V2_SCRIPTS_DIR / "error_patterns.py"
    if not script.exists():
        print(f"❌ Script lipsă: {script}")
        return
    if args and args[0] in ("detect", "list", "show"):
        cmd = ["python3", str(script)] + args
    else:
        cmd = ["python3", str(script), "list"] + args
    subprocess.run(cmd)


def cmd_intelligence(args):
    """Raport complet intelligence layer."""
    # Rulează toate analizele
    print("\n🧠 MEMORY INTELLIGENCE REPORT\n")
    for name, script_name, default_cmd in [
        ("Error Patterns", "error_patterns.py", "list"),
        ("Memory Cleanup", "memory_cleanup.py", "report"),
    ]:
        script = V2_SCRIPTS_DIR / script_name
        if script.exists():
            print(f"--- {name} ---")
            subprocess.run(["python3", str(script), default_cmd])
            print()
        else:
            print(f"  ⚠ {name}: script lipsă")

    # Fact promoter scan
    script = V2_SCRIPTS_DIR / "fact_promoter.py"
    if script.exists():
        print("--- Fact Promoter ---")
        subprocess.run(["python3", str(script), "scan"])


